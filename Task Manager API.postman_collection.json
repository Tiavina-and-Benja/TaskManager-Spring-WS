        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Vérifier que la réponse est OK\r",
                  "if (pm.response.code === 200) {\r",
                  "    let jsonData = pm.response.json();\r",
                  "    \r",
                  "    // Vérifier que le token existe\r",
                  "    if (jsonData.data && jsonData.data.token) {\r",
                  "        // Stocker le token dans une variable de collection\r",
                  "        pm.environment.set(\"token\", jsonData.data.token);\r",
                  "        console.log(\"Token enregistré dans la variable de collection:\", jsonData.data.token);\r",
                  "    } else {\r",
                  "        console.warn(\"Token non trouvé dans la réponse !\");\r",
                  "    }\r",
                  "} else {\r",
                  "    console.error(\"Login échoué avec le code:\", pm.response.code);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@mail.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
